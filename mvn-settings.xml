<?xml version="1.0" encoding="UTF-8"?>
<!--
	Minimal Maven settings that adds the TopLogic Nexus as a plugin repository.
	Passed via 'mvn -s' by the tl-mcp mcpServers entry so that the tl-mcp-server
	plugin resolves without requiring the user to modify their personal
	~/.m2/settings.xml. Central remains the implicit default for everything else.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">

	<profiles>
		<profile>
			<id>toplogic-nexus</id>
			<pluginRepositories>
				<pluginRepository>
					<id>tl-releases</id>
					<url>https://dev.top-logic.com/nexus/repository/toplogic/</url>
					<releases><enabled>true</enabled></releases>
					<snapshots><enabled>false</enabled></snapshots>
				</pluginRepository>
				<pluginRepository>
					<id>tl-snapshots</id>
					<url>https://dev.top-logic.com/nexus/repository/toplogic-snapshots/</url>
					<releases><enabled>false</enabled></releases>
					<snapshots><enabled>true</enabled></snapshots>
				</pluginRepository>
			</pluginRepositories>
		</profile>
	</profiles>

	<activeProfiles>
		<activeProfile>toplogic-nexus</activeProfile>
	</activeProfiles>

</settings>
